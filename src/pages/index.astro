---
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import RepositoryCard from "@/components/mdx/RepositoryCard.astro";
import PostCard from "@/components/PostCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllPosts, getPostsWithStats, sortPostsByDate } from "@/utils/blogUtils";

const latestPosts = await getPostsWithStats(
  sortPostsByDate(await getAllPosts()).slice(0, 3),
);

const featuredRepos = [
  { repo: "OpenScientificResearchGroup/Core", isPinned: true },
  { repo: "Altasc/JumpJump", isPinned: false },
];
---

<BaseLayout title="主页 | Home">
  <MainCard
    title="主页 | Home"
    description="还是有个主页比较好（AI真是太好用啦！）"
    textOverlay="主页"
    infoIcon="lucide:info"
  >

    <div class="space-y-10">
      <!-- Hero Section -->
      <section class="py-2">
        <div class="flex flex-col items-center text-center">
          <h1
            class="text-4xl font-bold mb-4 bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent leading-loose">
            欢迎来到比特终端<br />
            Welcome to BitTerminal
          </h1>
          <blockquote class="max-w-3xl w-full mb-8">
            <p class="text-xl italic text-base-content/80 text-center">“丢掉幻想，准备斗争！”</p>
            <footer class="mt-3 italic text-base md:text-lg text-base-content/70 text-right max-w-2xl mx-auto pr-2">——毛泽东</footer>
          </blockquote>
        </div>
      </section>

      <section class="py-2">
        <h2 class="text-2xl font-bold mb-4 flex items-center gap-2">
          <Icon name="lucide:user-round" class="w-6 h-6 text-primary" />
          <span>关于作者 | About Author</span>
        </h2>
        <div class="card bg-base-200/70 p-6">
          <p class="text-base leading-8 text-base-content/85">
            就一臭写代码的
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a href="/about" class="btn btn-primary btn-sm gap-2">
              <Icon name="lucide:user" class="w-4 h-4" />
              <span>More</span>
            </a>
            <a href="https://github.com/Altasc" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm gap-2">
              <Icon name="lucide:github" class="w-4 h-4" />
              <span>GitHub Profile</span>
            </a>
          </div>
        </div>
      </section>

      <section class="py-2">
        <div class="mb-6 flex items-center justify-between gap-4">
          <h2 class="text-2xl font-bold flex items-center gap-2">
            <Icon name="lucide:newspaper" class="w-6 h-6 text-primary" />
            <span>最新记录 | Latest Records</span>
          </h2>
          <a href="/blog" class="btn btn-ghost btn-sm gap-2">
            <span>View All</span>
            <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </div>

        {
          latestPosts.length > 0 ? (
            <div class="space-y-4">
              {latestPosts.map((post) => (
                <PostCard
                  title={post.data.title}
                  image={post.data.image}
                  description={post.data.description}
                  url={`/blog/${post.slug}`}
                  pubDate={post.data.pubDate}
                  badge={post.data.badge}
                  categories={post.data.categories}
                  tags={post.data.tags}
                  word={post.remarkPluginFrontmatter.totalCharCount}
                  time={post.remarkPluginFrontmatter.readingTime}
                />
              ))}
            </div>
          ) : (
            <div class="card bg-base-200/70 p-6 text-base-content/70">
              No posts yet. Start writing your first blog post in the content folder.
            </div>
          )
        }
      </section>

      <section class="py-2">
        <div class="mb-6 flex items-center justify-between gap-4">
          <h2 class="text-2xl font-bold flex items-center gap-2">
            <Icon name="lucide:github" class="w-6 h-6 text-primary" />
            <span>精选仓库 | Featured Repositories</span>
          </h2>
          <a
            href="https://github.com/Altasc?tab=repositories"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-ghost btn-sm gap-2"
          >
            <span>More Repos</span>
            <Icon name="lucide:external-link" class="w-4 h-4" />
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
          {
            featuredRepos.map((item) => (
              <RepositoryCard repo={item.repo} isPinned={item.isPinned} />
            ))
          }
        </div>
      </section>
    </div>
  </MainCard>
</BaseLayout>
